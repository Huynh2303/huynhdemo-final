@model IEnumerable<Demo_web_MVC.Models.ViewModel.Address.AddressViewModel>
@{
    Layout = null;
}

<section class="flex flex-col gap-lg">
    <!-- Section Header -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center bg-white p-lg rounded-xl shadow-sm border border-gray-100">
        <div>
            <h1 class="text-display-lg font-display-lg text-on-surface">Địa chỉ của tôi </h1>
            
        </div>
        <button type="button"
                data-url="/Adress/CreatePartail"
                class="mt-4 md:mt-0 flex items-center gap-2 bg-primary-container text-white px-6 py-3 rounded-lg font-label-bold hover:brightness-110 active:scale-95 transition-all shadow-lg shadow-sky-500/20">

            <span class="material-symbols-outlined text-[20px]">
                add
            </span>

            Thêm địa chỉ mới
        </button>
    </div>
    <!-- Razor Logic: Address List -->
    <div class="grid grid-cols-1 gap-md">
        @foreach (var item in Model)
        {
            <div class="group relative flex flex-col md:flex-row justify-between bg-white p-lg rounded-xl shadow-sm hover:shadow-md transition-all border border-gray-100 hover:border-sky-200">
                <div class="flex flex-col gap-2">
                    <div class="flex items-center gap-3">
                        <span class="font-headline-md text-on-surface">@item.RecipientName</span>
                        @if (item.IsDefault)
                        {
                            <span class="bg-sky-50 text-sky-600 text-[10px] font-bold px-2 py-0.5 rounded-full border border-sky-100 uppercase tracking-tighter">Mặc định</span>
                        }
                    </div>
                    <div class="flex items-center gap-2 text-on-surface-variant">
                        <span class="material-symbols-outlined text-sm">call</span>
                        <span class="text-body-sm">@item.PhoneNumber</span>
                    </div>
                    <div class="flex items-start gap-2 text-on-surface-variant mt-1">
                        <span class="material-symbols-outlined text-sm mt-0.5">location_on</span>
                        <span class="text-body-sm max-w-lg">
                            @item.AddressLine, @item.City, @item.Country
                        </span>
                    </div>
                </div>
                <div class="flex flex-col items-end justify-between mt-4 md:mt-0 gap-4">
                    <div class="flex gap-4">
                        <button data-url="/Adress/Edit/@item.Id"
                                class="text-sky-500 hover:text-sky-700 font-label-bold text-sm transition-colors">

                            Cập nhật

                        </button>
                        <form asp-action="Delete" asp-controller="Adress"
                              asp-route-id="@item.Id"
                              method="post"
                              class="inline-form"
                              onsubmit="return confirm('Bạn có chắc muốn xóa địa chỉ này không?');">
                            <button type="submit" class="text-error hover:text-red-700 font-label-bold text-sm transition-colors">Xóa</button>
                        </form>
                    </div>
                    @if (!item.IsDefault)
                    {
                        <form asp-action="SetDefault"
                              asp-route-id="@item.Id"
                              method="post"
                              class="inline-form">
                            <button type="submit" class="border border-outline-variant text-on-surface-variant px-4 py-2 rounded-lg text-xs font-label-bold hover:bg-surface-container-low hover:border-sky-500 hover:text-sky-600 transition-all">Thiết lập mặc định</button>
                        </form>
                    }
                    else
                    {
                        <button class="border border-gray-100 bg-gray-50 text-gray-400 px-4 py-2 rounded-lg text-xs font-label-bold cursor-not-allowed" disabled>Địa chỉ mặc định</button>
                    }
                </div>
            </div>
        }
    </div>
</section>