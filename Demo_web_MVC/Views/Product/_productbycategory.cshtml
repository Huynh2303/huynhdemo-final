@model List<Demo_web_MVC.Models.ViewModel.Product.ProductViewModel>
@using System.Globalization
@using System.Linq
@using Demo_web_MVC.Models.ViewModel.Product



@if (Model == null || !Model.Any())
{
    <div class="bg-white rounded-xl p-xl text-center shadow-sm border border-slate-100">
        <span class="material-symbols-outlined text-5xl text-outline mb-sm">
            inventory_2
        </span>

        <h3 class="text-title-lg font-bold mb-sm">
            Không có sản phẩm trong danh mục này
        </h3>

        <a asp-controller="Product"
           asp-action="Index"
           class="inline-flex mt-md px-lg py-sm rounded-lg bg-primary text-white no-underline">
            Xem tất cả sản phẩm
        </a>
    </div>
}
else
{
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-lg">
        @foreach (var item in Model)
        {
            var imagePath = item.imageUrl != null && item.imageUrl.Any()
            ? item.imageUrl.First()
            : Url.Content("~/uploads/images/no-image.jpg");

            var price = item.Variants != null && item.Variants.Any()
            ? item.Variants.Min(v => v.Price)
            : 0;

            var stock = item.Variants != null && item.Variants.Any()
            ? item.Variants.Sum(v => v.Stock)
            : 0;

            <div class="bg-white rounded-xl shadow-sm hover:shadow-xl transition-all duration-300 group flex flex-col border border-slate-100 overflow-hidden hover:-translate-y-1">
                <div class="relative aspect-[4/5] overflow-hidden">
                    <button class="absolute top-3 right-3 z-10 w-8 h-8 rounded-full bg-white/80 backdrop-blur-sm flex items-center justify-center text-slate-400 hover:text-error transition-colors">
                        <span class="material-symbols-outlined text-[20px]">favorite</span>
                    </button>

                    <a asp-controller="Product" asp-action="Details" asp-route-id="@item.Id">
                        <img alt="@item.Name"
                             class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                             src="@imagePath"
                             onerror="this.onerror=null;this.src='@Url.Content("~/uploads/images/no-image.jpg")';" />
                    </a>
                </div>

                <div class="p-lg flex flex-col flex-1">
                    <span class="text-label-bold font-label-bold text-outline uppercase mb-1">
                        @item.Brand
                    </span>

                    <h3 class="text-headline-md font-headline-md mb-2 line-clamp-2 min-h-[56px] leading-7">
                        @item.Name
                    </h3>

                    <div class="flex items-center gap-1 mb-4">
                        <div class="flex text-tertiary-container">
                            <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL';">star</span>
                            <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL';">star</span>
                            <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL';">star</span>
                            <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL';">star</span>
                            <span class="material-symbols-outlined text-sm">star_half</span>
                        </div>

                        <span class="text-[12px] text-outline">
                            (@stock)
                        </span>
                    </div>

                    <div class="mt-auto flex items-center justify-between">
                        <span class="text-price-lg text-on-background">
                            @string.Format(new CultureInfo("vi-VN"), "{0:N0} ₫", price)
                        </span>

                        <button class="bg-primary-container text-white p-2 rounded-lg hover:brightness-110 active:scale-90 transition-all">
                            <span class="material-symbols-outlined">add_shopping_cart</span>
                        </button>
                    </div>
                </div>
            </div>
        }

    </div>
}