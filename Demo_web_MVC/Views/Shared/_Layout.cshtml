@{
    var title = ViewData["Title"] ?? "Demo_web_MVC";

    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

    var isSellerPage =
        controller.Equals("Seller", StringComparison.OrdinalIgnoreCase);

    var isShopPage =
        controller.Equals("Home", StringComparison.OrdinalIgnoreCase) ||
        controller.Equals("Product", StringComparison.OrdinalIgnoreCase) ||
        controller.Equals("Cart", StringComparison.OrdinalIgnoreCase) ||
        controller.Equals("Chat", StringComparison.OrdinalIgnoreCase) ||
        controller.Equals("Search", StringComparison.OrdinalIgnoreCase) ||
        controller.Equals("Chat", StringComparison.OrdinalIgnoreCase) ||
        controller.Equals("Oder", StringComparison.OrdinalIgnoreCase) ||
        isSellerPage;

    var cartCount = ViewBag.CartCount != null ? (int)ViewBag.CartCount : 0;

    string SellerActive(string actionName)
    {
        return action.Equals(actionName, StringComparison.OrdinalIgnoreCase)
            ? "bg-sky-50 text-sky-600 font-semibold border-l-4 border-sky-500"
            : "text-slate-600 hover:bg-slate-100 hover:text-sky-600";
    }
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Demo_web_MVC.styles.css" asp-append-version="true" />

    @RenderSection("Styles", required: false)

    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@title</title>

    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@100;400;500;600;700;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    <script src="~/js/tailwind-config.js"></script>

    <style>
        .no-scrollbar::-webkit-scrollbar {
            display: none;
        }

        .no-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }

        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
    </style>
</head>

<body class="@(isShopPage ? "shop-layout-body" : "")">

    @if (isShopPage)
    {
        <!-- Header riêng cho khu shop -->
        <header class="bg-white/90 dark:bg-slate-900/90 backdrop-blur-md sticky top-0 z-50 border-b border-slate-200 dark:border-slate-800 shadow-lg shadow-black/5">
            <div class="flex flex-col w-full max-w-7xl mx-auto px-4 md:px-8 py-3">
                <div class="flex items-center justify-between gap-gutter">

                    <a class="text-2xl font-black text-sky-500 dark:text-sky-400 shrink-0 no-underline"
                       asp-controller="Product"
                       asp-action="Index">
                        ASP.NET Commerce
                    </a>

                    <div class="hidden md:flex flex-1 max-w-2xl px-gutter">
                        <div class="relative w-full group">
                            <form asp-controller="Search" asp-action="Index" method="get">
                                <input name="searchQuery"
                                       class="w-full bg-surface-container-low border-outline-variant rounded-lg py-2 pl-10 pr-4 focus:ring-2 focus:ring-primary-container focus:border-transparent transition-all outline-none"
                                       placeholder="Search products..."
                                       type="text" />

                                <button type="submit"
                                        class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline">
                                    search
                                </button>
                            </form>
                        </div>
                    </div>

                    <div class="flex items-center gap-sm md:gap-lg">
                        <div id="chat-dropdown-container">
                            @await Component.InvokeAsync("NotificationsDropdown")
                        </div>
                        
                        <div id="chat-dropdown-container">
                            @await Component.InvokeAsync("ChatDropdown")
                        </div>
                        
                        <form asp-controller="Cart" asp-action="Index" method="post">
                            <button type="submit"
                                    class="p-2 text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-md transition-all active:scale-90 relative">
                                <span class="material-symbols-outlined">shopping_cart</span>
                                <span class="absolute top-1 right-1 w-4 h-4 bg-primary-container text-white text-[10px] flex items-center justify-center rounded-full">
                                    @cartCount
                                </span>
                            </button>
                        </form>

                        @if (!User.Identity!.IsAuthenticated)
                        {
                            <form asp-controller="User" asp-action="Login" method="get">
                                <button type="submit"
                                        class="p-2 text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-md transition-all active:scale-90">
                                    <span class="ml-2">Đăng nhập</span>
                                </button>
                            </form>
                        }

                        <partial name="_MenuManagePartial" />
                    </div>
                </div>
            </div>
        </header>
    }
    else
    {
        <!-- Navbar mặc định cho trang không phải shop -->
        <header class="bg-white/90 dark:bg-slate-900/90 backdrop-blur-md sticky top-0 z-50 border-b border-slate-200 dark:border-slate-800 shadow-lg shadow-black/5">
            <div class="flex flex-col w-full max-w-7xl mx-auto px-4 md:px-8 py-3">
                <div class="flex items-center justify-between gap-gutter">

                    <a class="text-2xl font-black text-sky-500 dark:text-sky-400 shrink-0 no-underline"
                       asp-controller="Product"
                       asp-action="Index">
                        ASP.NET Commerce
                    </a>

                    <div class="hidden md:flex flex-1 max-w-2xl px-gutter">
                        <div class="relative w-full group">
                            <form asp-controller="Search" asp-action="Index" method="get">
                                <input name="searchQuery"
                                       class="w-full bg-surface-container-low border-outline-variant rounded-lg py-2 pl-10 pr-4 focus:ring-2 focus:ring-primary-container focus:border-transparent transition-all outline-none"
                                       placeholder="Search products..."
                                       type="text" />

                                <button type="submit"
                                        class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline">
                                    search
                                </button>
                            </form>
                        </div>
                    </div>

                    <div class="flex items-center gap-sm md:gap-lg">
                        <div id="chat-dropdown-container">
                            @await Component.InvokeAsync("NotificationsDropdown")
                        </div>

                        <div id="chat-dropdown-container">
                            @await Component.InvokeAsync("ChatDropdown")
                        </div>
                        <form asp-controller="Cart" asp-action="Index" method="post">
                            <button type="submit"
                                    class="p-2 text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-md transition-all active:scale-90 relative">
                                <span class="material-symbols-outlined">shopping_cart</span>
                                <span class="absolute top-1 right-1 w-4 h-4 bg-primary-container text-white text-[10px] flex items-center justify-center rounded-full">
                                    @cartCount
                                </span>
                            </button>
                        </form>

                        @if (!User.Identity!.IsAuthenticated)
                        {
                            <div class="flex gap-2">
                                <form asp-controller="User" asp-action="Login" method="get">
                                    <button type="submit"
                                            class="p-2 text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-md transition-all active:scale-90">
                                        <span class="ml-2">Đăng nhập</span>
                                    </button>
                                </form>

                                <form asp-controller="User" asp-action="Register" method="get">
                                    <button type="submit"
                                            class="p-2 text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-md transition-all active:scale-90">
                                        <span class="ml-2">Đăng ký</span>
                                    </button>
                                </form>
                            </div>
                        }

                        @if (User.Identity!.IsAuthenticated)
                        {
                            <button class="p-2 text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-md transition-all active:scale-90">
                                <span class="material-symbols-outlined">person</span>
                            </button>
                        }
                    </div>
                </div>
            </div>
        </header>
    }

    @if (isSellerPage)
    {
        <!-- Sidebar chỉ cho Seller -->
        <aside class="fixed left-[calc((100vw-1200px)/2)] top-[73px] z-40 flex h-[calc(100vh-73px)] w-64 flex-col border-r border-slate-200 bg-white shadow-lg shadow-black/5">
            <nav class="flex-1 space-y-1 px-4 py-4">

                <a asp-action="Dashboard"
                   asp-controller="Seller"
                   class="flex items-center gap-3 rounded-lg px-4 py-3 text-sm font-medium no-underline transition-all @SellerActive("Dashboard")">
                    <span class="material-symbols-outlined text-[22px]">dashboard</span>
                    <span>Bảng điều khiển</span>
                </a>

                <a asp-action="ProductsManager"
                   asp-controller="Seller"
                   class="flex items-center gap-3 rounded-lg px-4 py-3 text-sm font-medium no-underline transition-all @SellerActive("ProductsManager")">
                    <span class="material-symbols-outlined text-[22px]">inventory_2</span>
                    <span>Sản phẩm</span>
                </a>

                <a asp-action="Statistics"
                   asp-controller="Seller"
                   class="flex items-center gap-3 rounded-lg px-4 py-3 text-sm font-medium no-underline transition-all @SellerActive("Statistics")">
                    <span class="material-symbols-outlined text-[22px]">query_stats</span>
                    <span>Thống kê</span>
                </a>

            </nav>

            <div class="space-y-3 border-t border-slate-200 px-4 py-4">

                <a asp-action="CreateProduct"
                   asp-controller="Seller"
                   class="flex w-full items-center justify-center gap-2 rounded-lg bg-sky-500 px-4 py-3 text-sm font-semibold text-white no-underline shadow-sm transition-all hover:bg-sky-600 active:scale-95">
                    <span class="material-symbols-outlined text-[20px]">add</span>
                    <span>Thêm sản phẩm</span>
                </a>

                <a asp-action="Logout"
                   asp-controller="User"
                   class="flex items-center gap-3 rounded-lg px-4 py-3 text-sm font-medium text-slate-600 no-underline transition-all hover:bg-slate-100 hover:text-slate-900">
                    <span class="material-symbols-outlined text-[22px]">logout</span>
                    <span>Đăng xuất</span>
                </a>

            </div>
        </aside>
        <main class="min-h-[calc(100vh-73px)] bg-slate-50">
            <div class="max-w-[1200px] mx-auto grid grid-cols-[256px_1fr]">
                <div></div>

                <div class="px-8 py-6">
                    @RenderBody()
                </div>
            </div>
        </main>
    }
    else
    {
        <main class="shop-main">
            @RenderBody()
        </main>
    }

    @if (isShopPage && !isSellerPage)
    {
        <footer class="bg-slate-50 dark:bg-slate-950 w-full mt-auto border-t border-slate-200 dark:border-slate-800">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-8 max-w-7xl mx-auto px-8 py-12">

                <div class="flex flex-col gap-4">
                    <span class="text-xl font-bold text-slate-900 dark:text-white">
                        ASP.NET Commerce
                    </span>

                    <p class="text-slate-500 dark:text-slate-400 text-body-sm leading-relaxed">
                        Điểm đến mua sắm trực tuyến dành cho các sản phẩm công nghệ, thiết bị điện tử và phụ kiện hiện đại.
                        Chúng tôi mang đến trải nghiệm mua sắm nhanh chóng, tiện lợi và đáng tin cậy cho mọi khách hàng.
                    </p>
                </div>

                <div class="flex flex-col gap-4">
                    <span class="text-sky-500 dark:text-sky-400 font-label-bold text-label-bold uppercase">
                        Hỗ trợ khách hàng
                    </span>

                    <nav class="flex flex-col gap-2">
                        <a class="text-slate-500 dark:text-slate-400 hover:text-sky-500 hover:underline transition-colors text-sm" href="#">
                            Liên hệ
                        </a>

                        <a class="text-slate-500 dark:text-slate-400 hover:text-sky-500 hover:underline transition-colors text-sm" href="#">
                            Thông tin giao hàng
                        </a>

                        <a class="text-slate-500 dark:text-slate-400 hover:text-sky-500 hover:underline transition-colors text-sm" href="#">
                            Chính sách đổi trả
                        </a>

                        <a class="text-slate-500 dark:text-slate-400 hover:text-sky-500 hover:underline transition-colors text-sm" href="#">
                            Trung tâm trợ giúp
                        </a>
                    </nav>
                </div>

                <div class="flex flex-col gap-4">
                    <span class="text-sky-500 dark:text-sky-400 font-label-bold text-label-bold uppercase">
                        Về chúng tôi
                    </span>

                    <nav class="flex flex-col gap-2">
                        <a class="text-slate-500 dark:text-slate-400 hover:text-sky-500 hover:underline transition-colors text-sm" href="#">
                            Giới thiệu
                        </a>

                        <a class="text-slate-500 dark:text-slate-400 hover:text-sky-500 hover:underline transition-colors text-sm" href="#">
                            Chính sách bảo mật
                        </a>

                        <a class="text-slate-500 dark:text-slate-400 hover:text-sky-500 hover:underline transition-colors text-sm" href="#">
                            Điều khoản sử dụng
                        </a>

                        <a class="text-slate-500 dark:text-slate-400 hover:text-sky-500 hover:underline transition-colors text-sm" href="#">
                            Tuyển dụng
                        </a>
                    </nav>
                </div>

                <div class="flex flex-col gap-4">
                    <span class="text-sky-500 dark:text-sky-400 font-label-bold text-label-bold uppercase">
                        Thông tin liên hệ
                    </span>

                    <div class="flex flex-col gap-3">

                        <div class="flex items-center gap-2 text-slate-500 dark:text-slate-400 text-sm">
                            <span class="material-symbols-outlined text-sky-500">
                                location_on
                            </span>
                            <span>Thái Nguyên, Việt Nam</span>
                        </div>

                        <div class="flex items-center gap-2 text-slate-500 dark:text-slate-400 text-sm">
                            <span class="material-symbols-outlined text-sky-500">
                                mail
                            </span>
                            <span>support@aspnetcommerce.com</span>
                        </div>

                        <div class="flex items-center gap-2 text-slate-500 dark:text-slate-400 text-sm">
                            <span class="material-symbols-outlined text-sky-500">
                                call
                            </span>
                            <span>0123 456 789</span>
                        </div>

                    </div>
                </div>

            </div>
        </footer>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        setInterval(async () => {

            const response = await fetch('/Chat/ChatDropdown');

            if (!response.ok) return;

            const html = await response.text();

            document.getElementById('chat-dropdown-container').innerHTML = html;

        }, 3000);
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>