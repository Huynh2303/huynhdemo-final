@model Demo_web_MVC.Models.ViewModel.UpdateBirthdayViewModel

@{
    ViewData["Title"] = "Cập nhật ngày sinh";
}

<div class="min-h-[70vh] flex items-center justify-center bg-gray-50 px-4">
    <div class="w-full max-w-md bg-white rounded-2xl shadow-lg border border-gray-100 p-8">

        <div class="text-center mb-6">
            <h1 class="text-2xl font-bold text-gray-800">
                Cập nhật ngày sinh
            </h1>

            <p class="text-gray-500 mt-2 text-sm">
                Vui lòng nhập ngày sinh để tiếp tục sử dụng hệ thống.
            </p>
        </div>

        <form asp-action="UpdateBirthday"
              asp-controller="User"
              method="post"
              class="space-y-5">

            @Html.AntiForgeryToken()

            <div>
                <label asp-for="DateOfBirth"
                       class="block text-sm font-medium text-gray-700 mb-2">
                    Ngày sinh
                </label>

                <input asp-for="DateOfBirth"
                       type="date"
                       class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-primary focus:border-primary outline-none transition" />

                <span asp-validation-for="DateOfBirth"
                      class="text-red-500 text-sm mt-1 block"></span>
            </div>

            <button type="submit"
                    class="w-full py-3 rounded-xl bg-primary text-white font-semibold hover:opacity-90 transition">
                Lưu ngày sinh
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}