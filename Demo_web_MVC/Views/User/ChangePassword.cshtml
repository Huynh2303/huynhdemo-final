@model Demo_web_MVC.Models.ViewModel.ChangePasswordViewModel
@{
    Layout = null;
}
<div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">

    <div class="mb-6">
        <h2 class="text-2xl font-bold text-gray-800">
            Đổi mật khẩu
        </h2>

        <p class="text-gray-500 mt-1">
            Cập nhật mật khẩu mới để bảo mật tài khoản
        </p>
    </div>

    <form asp-action="ChangePassword" method="post" class="space-y-5">

        <div asp-validation-summary="ModelOnly"
             class="text-red-500 text-sm">
        </div>

        <!-- Mật khẩu cũ -->
        <div>
            <label asp-for="OldPassword"
                   class="block mb-2 text-sm font-semibold text-gray-700">
                Mật khẩu hiện tại
            </label>

            <input asp-for="OldPassword"
                   type="password"
                   class="w-full rounded-xl border border-gray-300 px-4 py-3
                          focus:outline-none focus:ring-2 focus:ring-sky-500
                          focus:border-sky-500 transition" />

            <span asp-validation-for="OldPassword"
                  class="text-red-500 text-sm">
            </span>
        </div>

        <!-- Mật khẩu mới -->
        <div>
            <label asp-for="NewPassword"
                   class="block mb-2 text-sm font-semibold text-gray-700">
                Mật khẩu mới
            </label>

            <input asp-for="NewPassword"
                   type="password"
                   class="w-full rounded-xl border border-gray-300 px-4 py-3
                          focus:outline-none focus:ring-2 focus:ring-sky-500
                          focus:border-sky-500 transition" />

            <span asp-validation-for="NewPassword"
                  class="text-red-500 text-sm">
            </span>
        </div>

        <!-- Xác nhận mật khẩu -->
        <div>
            <label asp-for="ConfirmPassword"
                   class="block mb-2 text-sm font-semibold text-gray-700">
                Xác nhận mật khẩu mới
            </label>

            <input asp-for="ConfirmPassword"
                   type="password"
                   class="w-full rounded-xl border border-gray-300 px-4 py-3
                          focus:outline-none focus:ring-2 focus:ring-sky-500
                          focus:border-sky-500 transition" />

            <span asp-validation-for="ConfirmPassword"
                  class="text-red-500 text-sm">
            </span>
        </div>

        <!-- Button -->
        <div class="pt-2">
            <button type="submit"
                    class="bg-sky-500 hover:bg-sky-600 text-white
                           px-6 py-3 rounded-xl font-semibold transition">
                Đổi mật khẩu
            </button>
        </div>

    </form>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}