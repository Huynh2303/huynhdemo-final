    <!-- Nội dung bên phải -->
    <section id="main-content" class="min-w-0 w-full overflow-hidden"></section>

</main>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const mainContent = document.getElementById('main-content');

        const urls = {
            MyAddresses: '/Adress/IndexPartial',
            ProfileSettings: '/User/ChangePassword',
            OrderHistory: '/Oder/Index'
        };

        function setActiveMenu(activeItem) {
            document.querySelectorAll('.menu-item').forEach(item => {
                item.classList.remove('bg-sky-50', 'text-sky-600', 'font-bold');
                item.classList.add('text-gray-500');
            });

            activeItem.classList.add('bg-sky-50', 'text-sky-600', 'font-bold');
            activeItem.classList.remove('text-gray-500');
        }

            async function loadPartial(url) {
        try {
            const response = await fetch(url);

            // Nếu bị redirect sang Login
            if (response.redirected &&
                response.url.toLowerCase().includes('/login')) {

                window.location.href = response.url;
                return;
            }

            if (response.status === 401 || response.status === 403) {
                window.location.href = '/User/Login';
                return;
            }

            if (!response.ok) {
                throw new Error(response.status);
            }

            mainContent.innerHTML = await response.text();
        }
        catch {
            mainContent.innerHTML =
                '<p class="text-red-500">Không tải được nội dung.</p>';
        }
    }

        // Click menu trái
        document.querySelectorAll('.menu-item').forEach(item => {
            item.addEventListener('click', e => {
                e.preventDefault();

                const target = item.dataset.target;
                const url = urls[target];

                if (!url) {
                    return;
                }

                setActiveMenu(item);
                loadPartial(url);
            });
        });

        // Load tab mặc định
        const defaultTab = localStorage.getItem('defaultTab') || 'MyAddresses';
        const defaultMenu = document.querySelector(`.menu-item[data-target="${defaultTab}"]`);

        if (defaultMenu) {
            defaultMenu.click();
        }

        localStorage.removeItem('defaultTab');

        // Load partial bằng data-url
        document.addEventListener('click', e => {
            const btn = e.target.closest('[data-url]');

            if (!btn) {
                return;
            }

            e.preventDefault();
            loadPartial(btn.dataset.url);
        });

        // Submit form ajax cho địa chỉ
        document.addEventListener('submit', async e => {
            const form = e.target;

            const isAjaxForm =
                form.dataset.ajax ||
                form.action.includes('/Adress/Create') ||
                form.action.includes('/Adress/Edit') ||
                form.action.includes('/Adress/Delete') ||
                form.action.includes('/Adress/SetDefault');

            if (!isAjaxForm) {
                return;
            }

            e.preventDefault();

            try {
                const response = await fetch(form.action, {
                    method: form.method || 'POST',
                    body: new FormData(form)
                });

                if (!response.ok) {
                    throw new Error(response.status);
                }

                mainContent.innerHTML = await response.text();
            } catch {
                mainContent.innerHTML = '<p class="text-red-500">Lỗi xảy ra khi submit.</p>';
            }
        });
    });
</script>