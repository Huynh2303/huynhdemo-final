@model List<Demo_web_MVC.Models.ViewModel.NotificationViewModel>

@{
    ViewData["Title"] = "Thông báo";
}

<div class="max-w-4xl mx-auto py-8 space-y-6">

    <div class="flex items-center justify-between">
        <h1 class="text-2xl font-bold text-slate-800">
            Thông báo của tôi
        </h1>

        <form asp-controller="Notifications"
              asp-action="MarkAllAsRead"
              method="post">
            <button type="submit"
                    class="px-4 py-2 rounded-lg bg-primary text-white font-semibold hover:bg-primary/90">
                Đánh dấu tất cả đã đọc
            </button>
        </form>
    </div>

    <div class="bg-white border border-slate-200 rounded-xl overflow-hidden shadow-sm">

        @if (Model == null || !Model.Any())
        {
            <div class="p-6 text-slate-500">
                Bạn chưa có thông báo nào.
            </div>
        }
        else
        {
            foreach (var item in Model)
            {
                <a asp-controller="Notifications"
                   asp-action="Open"
                   asp-route-id="@item.Id"
                   class="block p-5 border-b hover:bg-slate-50 no-underline">

                    <div class="flex gap-4">
                        <div class="pt-2">
                            @if (!item.IsRead)
                            {
                                <span class="block w-3 h-3 bg-red-500 rounded-full"></span>
                            }
                            else
                            {
                                <span class="block w-3 h-3 bg-slate-300 rounded-full"></span>
                            }
                        </div>

                        <div class="flex-1">
                            <div class="font-bold text-slate-800">
                                @item.Title
                            </div>

                            <div class="text-sm text-slate-600 mt-1">
                                @item.Content
                            </div>

                            <div class="text-xs text-slate-400 mt-2">
                                @item.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                            </div>
                        </div>
                    </div>
                </a>
            }
        }
    </div>
</div>