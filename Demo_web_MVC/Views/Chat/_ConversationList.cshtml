@model List<Demo_web_MVC.Models.Conversation>

@{
    var conversations = Model
        .Where(x => User.IsInRole("ADMIN") || x.Type != "SystemSupport")
        .ToList();
}

@if (User.IsInRole("STAFF"))
{
    <a asp-controller="Chat"
       asp-action="Support"
       class="flex items-center gap-3 bg-white rounded-xl px-3 py-3 shadow-sm hover:shadow-md transition border border-slate-100">
        <div class="w-11 h-11 rounded-full bg-sky-100 flex items-center justify-center text-sky-600 font-bold">
            S
        </div>

        <div class="flex-1 min-w-0">
            <div class="font-semibold text-sm text-slate-800">Hỗ trợ hệ thống</div>
            <div class="text-xs text-slate-500 truncate">Liên hệ quản trị viên</div>
        </div>

        <div class="w-3 h-3 rounded-full bg-sky-500"></div>
    </a>

    <a asp-controller="Chat"
       asp-action="CustomerChats"
       class="flex items-center gap-3 bg-white rounded-xl px-3 py-3 shadow-sm hover:shadow-md transition border border-slate-100">
        <div class="w-11 h-11 rounded-full bg-orange-100 flex items-center justify-center text-orange-600 font-bold">
            K
        </div>

        <div class="flex-1 min-w-0">
            <div class="font-semibold text-sm text-slate-800">Khách hàng</div>
            <div class="text-xs text-slate-500 truncate">Xem hội thoại với khách mua hàng</div>
        </div>

        <div class="w-3 h-3 rounded-full bg-sky-500"></div>
    </a>

    return;
}

@if (!User.IsInRole("ADMIN"))
{
    <a asp-controller="Chat"
       asp-action="Support"
       class="flex items-center gap-3 bg-white rounded-xl px-3 py-3 shadow-sm hover:shadow-md transition border border-slate-100">
        <div class="w-11 h-11 rounded-full bg-sky-100 flex items-center justify-center text-sky-600 font-bold">
            S
        </div>

        <div class="flex-1 min-w-0">
            <div class="font-semibold text-sm text-slate-800">Hỗ trợ hệ thống</div>
            <div class="text-xs text-slate-500 truncate">Liên hệ quản trị viên</div>
        </div>

        <div class="w-3 h-3 rounded-full bg-sky-500"></div>
    </a>
}

@if (!conversations.Any())
{
    <div class="bg-white rounded-xl p-6 text-center text-slate-500 text-sm shadow-sm border border-slate-100">
        Chưa có cuộc hội thoại nào.
    </div>
}
else
{
    @foreach (var conversation in conversations)
    {
        <a asp-controller="Chat"
           asp-action="Detail"
           asp-route-id="@conversation.Id"
           class="flex items-center gap-3 bg-white rounded-xl px-3 py-3 shadow-sm hover:shadow-md transition border border-slate-100">

            <div class="w-11 h-11 rounded-full bg-slate-200 flex items-center justify-center flex-shrink-0">
                <span class="text-sm font-bold text-slate-600">
                    @(conversation.Type == "SystemSupport" ? "A" : "O")
                </span>
            </div>

            <div class="flex-1 min-w-0">

                <div class="flex items-center justify-between gap-2">
                    <div class="font-semibold text-sm text-slate-800 truncate">
                        @if (conversation.Type == "SystemSupport")
                        {
                            var participant = conversation.Participants.FirstOrDefault();
                            <span>Hỗ trợ - @(participant?.User?.FullName ?? "Người dùng")</span>
                        }
                        else
                        {
                            <span>Đơn hàng #@conversation.OrderId</span>
                        }
                </div>

                <div class="text-[10px] text-slate-400 whitespace-nowrap">
                    @((conversation.LastMessageAt ?? conversation.CreatedAt).ToString("HH:mm"))
                </div>
            </div>

            <div class="text-xs text-slate-500 truncate mt-1">
                @(string.IsNullOrEmpty(conversation.LastMessage)
                            ? "Chưa có tin nhắn"
                            : conversation.LastMessage)
        </div>

            </div>

            <div class="w-3 h-3 rounded-full bg-sky-500 flex-shrink-0"></div>

        </a>
    }
}