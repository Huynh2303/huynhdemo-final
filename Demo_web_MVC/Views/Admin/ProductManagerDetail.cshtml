@model Demo_web_MVC.Models.ViewModel.Admin.ProductManagerDetailViewModel

<div class="p-6 space-y-6">

    <!-- Header nội dung -->
    <div class="border-b pb-4 pr-12">
        <h2 class="text-xl font-semibold text-gray-800">
            @Model.Name
        </h2>

        <p class="text-sm text-gray-500">
            ID: #@Model.Id
        </p>
    </div>

    <!-- Thông tin chung -->
    <div class="grid grid-cols-3 gap-4">

        <div>
            <p class="text-sm text-gray-500">Danh mục</p>
            <p class="font-medium text-gray-800">
                @(string.IsNullOrEmpty(Model.CategoryName) ? "Không có" : Model.CategoryName)
            </p>
        </div>

        <div>
            <p class="text-sm text-gray-500">Thương hiệu</p>
            <p class="font-medium text-gray-800">
                @(string.IsNullOrEmpty(Model.Brand) ? "Không có" : Model.Brand)
            </p>
        </div>

        <div>
            <p class="text-sm text-gray-500">Trạng thái</p>

            @if (Model.IsDeleted)
            {
                <span class="text-red-500 font-medium">Đã ẩn</span>
            }
            else
            {
                <span class="text-green-600 font-medium">Đang bán</span>
            }
        </div>

    </div>

    <!-- Mô tả -->
    <div>
        <p class="text-sm text-gray-500 mb-1">Mô tả</p>

        <div class="bg-gray-50 rounded-lg p-3 text-sm text-gray-700">
            @(string.IsNullOrEmpty(Model.Description) ? "Không có mô tả" : Model.Description)
        </div>
    </div>

    <!-- Thống kê -->
    <div class="grid grid-cols-4 gap-3">

        <div class="border rounded-lg p-3">
            <p class="text-sm text-gray-500">Biến thể</p>
            <p class="text-xl font-bold text-gray-800">@Model.TotalVariants</p>
        </div>

        <div class="border rounded-lg p-3">
            <p class="text-sm text-gray-500">Tồn kho</p>
            <p class="text-xl font-bold text-gray-800">@Model.TotalStock</p>
        </div>

        <div class="border rounded-lg p-3">
            <p class="text-sm text-gray-500">Giá thấp</p>
            <p class="text-xl font-bold text-gray-800">
                @Model.MinPrice.ToString("N0") đ
            </p>
        </div>

        <div class="border rounded-lg p-3">
            <p class="text-sm text-gray-500">Giá cao</p>
            <p class="text-xl font-bold text-gray-800">
                @Model.MaxPrice.ToString("N0") đ
            </p>
        </div>

    </div>

    <!-- Ảnh sản phẩm -->
    <div>
        <h3 class="font-semibold text-gray-800 mb-3">Ảnh sản phẩm</h3>

        @if (Model.ProductImages != null && Model.ProductImages.Any())
        {
            <div class="flex gap-3 overflow-x-auto pb-2">
                @foreach (var image in Model.ProductImages)
                {
                    <img src="@image"
                         class="w-24 h-24 object-cover rounded-lg border"
                         alt="@Model.Name" />
                }
            </div>
        }
        else
        {
            <p class="text-sm text-gray-500">Không có ảnh sản phẩm</p>
        }
    </div>

    <!-- Biến thể -->
    <div>
        <h3 class="font-semibold text-gray-800 mb-3">Biến thể sản phẩm</h3>

        @if (Model.Variants != null && Model.Variants.Any())
        {
            <div class="overflow-x-auto border rounded-lg">
                <table class="w-full text-sm">

                    <thead class="bg-gray-50">
                        <tr>
                            <th class="p-3 text-left">Ảnh</th>
                            <th class="p-3 text-left">Màu</th>
                            <th class="p-3 text-left">Size</th>
                            <th class="p-3 text-left">Giá</th>
                            <th class="p-3 text-left">Kho</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model.Variants)
                        {
                            <tr class="border-t hover:bg-gray-50">

                                <td class="p-3">
                                    @if (item.ImageUrlsVariants != null && item.ImageUrlsVariants.Any())
                                    {
                                        <img src="@item.ImageUrlsVariants.First()"
                                             class="w-14 h-14 object-cover rounded border"
                                             alt="@Model.Name" />
                                    }
                                    else
                                    {
                                        <div class="w-14 h-14 rounded border bg-gray-100 flex items-center justify-center text-gray-400">
                                            <span class="material-symbols-outlined text-base">
                                                image
                                            </span>
                                        </div>
                                    }
                                </td>

                                <td class="p-3 text-gray-800">
                                    @(string.IsNullOrEmpty(item.Color) ? "Không có" : item.Color)
                                </td>

                                <td class="p-3 text-gray-800">
                                    @(string.IsNullOrEmpty(item.Size) ? "Không có" : item.Size)
                                </td>

                                <td class="p-3 font-semibold text-gray-800">
                                    @item.Price.ToString("N0") đ
                                </td>

                                <td class="p-3">
                                    @if (item.Stock <= 0)
                                    {
                                        <span class="text-red-500 font-medium">
                                            Hết hàng
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-green-600 font-medium">
                                            @item.Stock
                                        </span>
                                    }
                                </td>

                            </tr>
                        }
                    </tbody>

                </table>
            </div>
        }
        else
        {
            <p class="text-sm text-gray-500">Sản phẩm chưa có biến thể</p>
        }
    </div>

</div>