@model Demo_web_MVC.Models.ViewModel.Admin.OrderDetailManagementViewModel
@using Demo_web_MVC.Models

<div class="p-6 space-y-6">

    <div class="border-b pb-4 pr-12">
        <h2 class="text-xl font-semibold text-gray-800">
            Cập nhật trạng thái đơn hàng
        </h2>

        <p class="text-sm text-gray-500">
            Order ID: #@Model.Order.Id
        </p>
    </div>

    <div>
        <p class="text-sm text-gray-500 mb-1">
            Trạng thái hiện tại
        </p>

        <span class="inline-flex px-3 py-1 rounded-full bg-surface-container-low text-sm font-medium">
            @Model.Order.Status
        </span>
    </div>

    <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">
            Trạng thái mới
        </label>

        <select id="update-order-status-select"
                class="w-full border border-outline-variant rounded-xl px-4 py-3 outline-none focus:ring-2 focus:ring-primary/30">

            <option value="Confirmed">Confirmed</option>
            <option value="Processing">Pending</option>
            <option value="Shipping">Shipping</option>
            <option value="Completed">Completed</option>
            <option value="Cancelled">Cancelled</option>

        </select>
    </div>

    <div class="flex justify-end gap-3 pt-4 border-t">

        <button type="button"
                id="submit-update-order-status-btn"
                data-order-id="@Model.Order.Id"
                class="px-5 py-2.5 rounded-xl bg-primary text-white hover:opacity-90 transition-all">

            Cập nhật
        </button>

    </div>

</div>