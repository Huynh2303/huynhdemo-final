@model Demo_web_MVC.Models.ViewModel.Oder.OderViewModel
@using System.Security.Claims

@{
    var currentUserId = 0;

    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        int.TryParse(User.FindFirstValue(ClaimTypes.NameIdentifier), out currentUserId);
    }

    var address = Model.AddressViewModels?.FirstOrDefault();

    var sellerIds = Model.Items?
        .Where(x => x.SellerId != null)
        .Select(x => x.SellerId!.Value)
        .Distinct()
        .ToList() ?? new List<int>();
}

<main class="w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-xl">

<div class="w-full space-y-6">
        @if (TempData["Error"] != null)
        {
            <div class="px-4 py-3 rounded-lg bg-red-50 border border-red-200 text-red-700 font-medium">
                @TempData["Error"]
            </div>
        }
        <!-- Header -->
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
            <div>
                <h1 class="text-3xl font-bold flex items-center gap-4">
                    Đơn hàng #@Model.Id

                    <span class="px-3 py-1 text-xs font-bold uppercase tracking-wider bg-primary/10 text-primary border border-primary/20 rounded-full">
                        @Model.Status
                    </span>
                </h1>
            </div>

            <div class="flex gap-2">
                
            <a href="/Home/Index"
               onclick="localStorage.setItem('defaultTab','OrderHistory')"
               class="flex items-center gap-2 px-6 py-2.5 bg-white border border-primary text-primary font-bold rounded-lg hover:bg-primary/5 transition-all shadow-sm no-underline">

                <span class="material-symbols-outlined text-sm">arrow_back</span>

                Quay lại đơn hàng
            </a>
            </div>
        
        </div>

        <!-- Info -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

            <!-- Địa chỉ -->
            <div class="bg-white rounded-xl p-6 shadow-sm border border-slate-100 space-y-4">
                <div class="flex items-center gap-2 text-primary">
                    <span class="material-symbols-outlined">location_on</span>
                    <h3 class="text-xl font-semibold">Địa chỉ giao hàng</h3>
                </div>

                <div class="space-y-1">
                    <p class="font-bold">
                        @(address?.RecipientName ?? "Chưa có tên người nhận")
                    </p>

                    <p class="text-gray-500">
                        @(address?.PhoneNumber ?? "Chưa có số điện thoại")
                    </p>

                    <p class="text-gray-500">
                        @(address?.AddressLine ?? "Chưa có địa chỉ")
                    </p>

                    <p class="text-gray-500">
                        @address?.City @address?.Country
                    </p>
                </div>
            </div>

            <!-- Thanh toán -->
            <div class="bg-white rounded-xl p-6 shadow-sm border border-slate-100 space-y-4">
                <div class="flex items-center gap-2 text-primary">
                    <span class="material-symbols-outlined">credit_card</span>
                    <h3 class="text-xl font-semibold">Thanh toán</h3>
                </div>

                <div class="space-y-1">
                    <p class="font-bold">COD</p>
                    <p class="text-gray-500 text-sm">Mã đơn hàng: #@Model.Id</p>
                </div>
            </div>
        </div>

        <!-- Danh sách sản phẩm -->
        <div class="space-y-4">
            <h3 class="text-xl font-semibold px-2">
                Sản phẩm trong đơn (@(Model.Items?.Count() ?? 0))
            </h3>

            @if (Model.Items != null && Model.Items.Any())
            {
                foreach (var item in Model.Items)
                {
                    var itemTotal = item.Price * item.Quantity;

                    <div class="bg-white rounded-xl overflow-hidden shadow-sm border border-slate-100 hover:shadow-md transition-all">
                        <div class="flex gap-4 p-4">

                            <div class="w-[120px] h-[120px] overflow-hidden rounded-lg border shrink-0">
                                <img src="@item.Img"
                                     alt="@item.Name"
                                     class="w-full h-full object-cover" />
                            </div>

                            <div class="flex-1 flex flex-col justify-between">
                                <div>
                                    <h4 class="text-lg font-semibold">
                                        @item.Name
                                    </h4>

                                    <p class="text-sm text-gray-500 mt-1">
                                        Màu: @item.Variant?.Color | Size: @item.Variant?.Size
                                    </p>

                                    <p class="text-sm text-gray-500 mt-1">
                                        Số lượng: @item.Quantity
                                    </p>
                                </div>

                                <div class="flex justify-between items-end mt-4">
                                    <p class="text-sm text-gray-500">
                                        Đơn giá:
                                        <span class="font-semibold text-primary">
                                            @item.Price.ToString("N0") đ
                                        </span>
                                    </p>

                                    <p class="text-lg font-bold text-primary">
                                        @itemTotal.ToString("N0") đ
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="bg-white rounded-xl p-6 border text-center text-gray-500">
                    Không có sản phẩm trong đơn hàng.
                </div>
            }
        </div>

        <!-- Tổng tiền -->
        <div class="flex justify-end">
            <div class="w-full md:w-[400px] bg-white rounded-xl p-6 shadow-md border border-slate-100 space-y-4">
                <h3 class="text-xl font-semibold pb-2 border-b border-slate-100">
                    Tổng kết đơn hàng
                </h3>

                <div class="space-y-3">
                    <div class="flex justify-between text-gray-500">
                        <span>Tạm tính</span>
                        <span>@Model.TotalAmount.ToString("N0") đ</span>
                    </div>

                    <div class="flex justify-between text-gray-500">
                        <span>Phí vận chuyển</span>
                        <span>Miễn phí</span>
                    </div>

                    <div class="flex justify-between text-red-600">
                        <span>Giảm giá</span>
                        <span>0 đ</span>
                    </div>

                    <div class="pt-4 border-t border-slate-100 flex justify-between items-center">
                        <span class="text-lg font-semibold">Tổng tiền</span>
                        <span class="text-3xl font-bold text-primary">
                            @Model.TotalAmount.ToString("N0") đ
                        </span>
                    </div>
                </div>
                <div class="pt-4 border-t border-slate-100 space-y-3">
                @foreach (var sellerId in sellerIds)
                {
                    if (sellerId == currentUserId)
                    {
                        <div class="mt-3">
                            <button type="button"
                                    disabled
                                    class="inline-flex px-lg py-sm bg-gray-400 text-white rounded-lg cursor-not-allowed">
                                Không thể chat với shop của chính bạn
                            </button>

                            <p class="text-sm text-red-600 mt-2">
                                Đây là sản phẩm thuộc shop của bạn.
                            </p>
                        </div>
                    }
                    else
                    {
                        <a asp-controller="Chat"
                           asp-action="OrderSeller"
                           asp-route-orderId="@Model.Id"
                           asp-route-sellerId="@sellerId"
                           class="inline-flex mt-3 px-lg py-sm bg-sky-600 text-white rounded-lg hover:bg-sky-700 no-underline">
                            Chat với shop
                        </a>
                    }
                }
                </div>
            </div>
        </div>

    </div>
    </main>