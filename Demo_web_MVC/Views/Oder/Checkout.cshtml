@model Demo_web_MVC.Models.ViewModel.Oder.CheckoutViewModel

<main class="w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-xl">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_380px] gap-lg items-start">
            <!-- Left Column: Order Details -->
            <div class="flex-1 space-y-lg">
                <!-- Shipping Address Section -->
                <section class="bg-white rounded-xl p-lg shadow-black/5 shadow-[0px_4px_12px_rgba(0,0,0,0.05)] border border-outline-variant/20">
                    <div class="flex items-center gap-sm mb-md text-primary">
                        <span class="material-symbols-outlined" data-icon="location_on">location_on</span>
                        <h2 class="font-headline-md text-headline-md">Địa Chỉ Nhận Hàng</h2>
                        <button type="button"
                                data-url="/Adress/CreatePartail"
                                class="flex items-center gap-2 bg-primary-container text-white px-4 py-2 rounded-lg hover:brightness-110 transition">

                            <span class="material-symbols-outlined text-[20px]">
                                add
                            </span>
                            Thêm địa chỉ mới
                        </button>
                    </div>
                    <div class="space-y-md">
                        @if (Model.AddressViewModels.Any())
                        {
                            @foreach (var address in Model.AddressViewModels)
                            {
                                <label class="relative flex items-start p-md border rounded-lg cursor-pointer transition-all hover:border-primary-container @(address.IsDefault ? "border-primary-container bg-primary-fixed" : "")">
                                    <input class="mt-1 text-primary focus:ring-primary h-4 w-4 border-gray-300"
                                           name="selectedAddressId"
                                           type="radio"
                                           value="@address.Id"
                                           @(address.IsDefault ? "checked" : "") />
                                    <div class="ml-md flex-1">
                                        <div class="flex items-center gap-sm">
                                            <span class="font-label-bold text-body-base text-on-surface">@address.RecipientName | @address.PhoneNumber</span>
                                            @if (address.IsDefault)
                                            {
                                                <span class="bg-primary text-white text-[10px] px-2 py-0.5 rounded-sm uppercase font-bold tracking-wider">Mặc định</span>
                                            }
                                        </div>
                                       
                                        <p class="text-body-sm text-on-surface-variant">@address.City</p>
                                    </div>
                                </label>
                            }
                        }
                        else
                        {
                            <h1>bạn chưa có địa chỉ nào vui lòng tạo địa chỉ </h1>
                        }
                    </div>
                </section>
                <!-- Order Review Section -->
                <section class="bg-white rounded-xl p-lg shadow-black/5 shadow-[0px_4px_12px_rgba(0,0,0,0.05)] border border-outline-variant/20">
                    <div class="flex items-center gap-sm mb-md text-primary">
                        <span class="material-symbols-outlined" data-icon="package_2">package_2</span>
                        <h2 class="font-headline-md text-headline-md">Sản Phẩm</h2>
                    </div>
                    <div class="overflow-x-auto">

                        <table class="w-full text-left">
                            <thead>
                                <tr class="border-b border-outline-variant/30 text-on-surface-variant font-label-bold text-label-bold uppercase">
                                    <th class="pb-sm px-2">Sản phẩm</th>
                                    <th class="pb-sm px-2 text-center">Đơn giá</th>
                                    <th class="pb-sm px-2 text-center">Số lượng</th>
                                    <th class="pb-sm px-2 text-right">Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-outline-variant/20">
                                @foreach (var item in Model.CartItems)
                                {
                                    <tr>
                                        <td class="py-md px-2">
                                            <div class="flex items-center gap-md">
                                                <div class="w-16 h-16 rounded-lg bg-surface-container overflow-hidden flex-shrink-0">
                                                    <img class="w-full h-full object-cover" src="@item.ImageUrl" alt="@item.ProductName" />
                                                </div>
                                                <span class="font-body-base text-on-surface">@item.ProductName</span>
                                            </div>
                                        </td>
                                        <td class="py-md px-2 text-center font-body-base">₫@string.Format("{0:N0}", item.Price)</td>
                                        <td class="py-md px-2 text-center font-body-base">@item.Quantity</td>
                                        <td class="py-md px-2 text-right font-price-lg text-primary">₫@string.Format("{0:N0}", item.Price * item.Quantity)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </section>
                <!-- Payment Method Section -->
                <section class="bg-white rounded-xl p-lg shadow-black/5 shadow-[0px_4px_12px_rgba(0,0,0,0.05)] border border-outline-variant/20">
                    <div class="flex items-center gap-sm mb-md text-primary">
                        <span class="material-symbols-outlined" data-icon="payments">payments</span>
                        <h2 class="font-headline-md text-headline-md">Phương Thức Thanh Toán</h2>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-md">
                        <label class="flex items-center gap-md p-md border border-outline-variant rounded-lg cursor-pointer hover:bg-surface-container-low transition-colors has-[:checked]:border-primary has-[:checked]:bg-primary-fixed/10">
                            <input checked="" class="text-primary focus:ring-primary h-5 w-5" name="paymentMethod" type="radio" value="COD" />
                            <div class="flex items-center gap-sm">
                                <span class="material-symbols-outlined text-on-surface-variant">local_shipping</span>
                                <span class="font-body-base">Thanh toán khi nhận hàng (COD)</span>
                            </div>
                        </label>
                        @* <label class="flex items-center gap-md p-md border border-outline-variant rounded-lg cursor-pointer hover:bg-surface-container-low transition-colors has-[:checked]:border-primary has-[:checked]:bg-primary-fixed/10">
                            <input class="text-primary focus:ring-primary h-5 w-5" name="paymentMethod" type="radio" value="VNPay" />
                            <div class="flex items-center gap-sm">
                                <span class="material-symbols-outlined text-sky-600">account_balance_wallet</span>
                                <span class="font-body-base">VNPay (Thẻ ATM / QR Code)</span>
                            </div>
                        </label> *@
                    </div>
                </section>
            </div>
            <!-- Right Column: Order Summary -->
        <aside class="w-full">
                <div class="sticky top-24 bg-white rounded-xl p-lg shadow-[0px_8px_24px_rgba(0,0,0,0.1)] border border-outline-variant/30 flex flex-col gap-lg">
                    <h3 class="font-headline-md text-on-surface border-b border-outline-variant/20 pb-md">Tóm tắt đơn hàng</h3>
                    <div class="space-y-md">
                        <div class="flex justify-between text-on-surface-variant">
                            <span class="font-body-base">Tổng tiền hàng</span>
                            <span class="font-body-base">₫@string.Format("{0:N0}", Model.TotalAmount)</span>
                        </div>
                        <div class="flex justify-between text-on-surface-variant">
                            <span class="font-body-base">Phí vận chuyển</span>
                            <span class="font-body-base">Miễn phí</span>
                        </div>
                        <div class="flex justify-between text-on-surface-variant">
                            <span class="font-body-base">Giảm giá</span>
                            <span class="font-body-base">-₫0</span>
                        </div>
                        <div class="pt-md border-t border-dashed border-outline-variant flex justify-between items-end">
                            <span class="font-label-bold text-on-surface">Tổng thanh toán</span>
                            <span class="text-primary font-price-lg text-[32px]">₫@string.Format("{0:N0}", Model.TotalAmount)</span>
                        </div>
                    </div>
                    
                    <form asp-action="CreateOrder" asp-controller="Oder" class="mt-md" method="post" id="createOrderForm">
                        @Html.AntiForgeryToken()

                        @foreach (var item in Model.CartItems)
                        {
                            <input type="hidden" name="selectedCartItemIds" value="@item.Id" />
                        }

                        <input id="hiddenAddressId"
                               name="addressId"
                               type="hidden"
                               value="@(Model.SelectedAddressId ?? 0)" />

                        <input id="hiddenPayment"
                               name="paymentMethod"
                               type="hidden"
                               value="@Model.PaymentMethod" />

                        <button class="w-full bg-primary-container text-white font-bold py-lg rounded-lg text-body-base shadow-lg shadow-primary-container/20 hover:scale-[1.02] active:scale-[0.98] transition-all duration-300 uppercase tracking-wide"
                                type="submit">
                            Đặt hàng
                        </button>
                    </form>
                    
                    <div class="flex items-center gap-sm justify-center text-on-surface-variant opacity-70">
                        <span class="material-symbols-outlined text-sm" data-icon="shield_check">shield</span>
                        <span class="text-xs">Giao dịch được bảo mật bởi ASP .NET</span>
                    </div>
                </div>
            </aside>
        </div>
    </main>
    <script>
        document.getElementById('createOrderForm').addEventListener('submit', function (e) {
            const selectedPayment = document.querySelector('input[name="paymentMethod"]:checked');
            const selectedAddress = document.querySelector('input[name="selectedAddressId"]:checked');

            if (!selectedAddress) {
                e.preventDefault();
                alert('Vui lòng chọn địa chỉ nhận hàng.');
                return;
            }

            if (!selectedPayment) {
                e.preventDefault();
                alert('Vui lòng chọn phương thức thanh toán.');
                return;
            }

            document.getElementById('hiddenAddressId').value = selectedAddress.value;
            document.getElementById('hiddenPayment').value = selectedPayment.value;
        });
    </script>
    <script>
        document.addEventListener('click', async e => {

            const btn = e.target.closest('[data-url]');

            if (!btn) return;

            e.preventDefault();

            const url = btn.dataset.url;

            try {

                const response = await fetch(url);

                const html = await response.text();

                // tạo modal tạm
                let modal = document.getElementById('address-modal');

                if (!modal) {
                    modal = document.createElement('div');

                    modal.id = 'address-modal';

                    modal.className =
                        'fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4';

                    document.body.appendChild(modal);
                }

                modal.innerHTML = `
                    <div class="bg-white rounded-xl p-6 w-full max-w-2xl relative overflow-auto max-h-[90vh]">

                        <button id="close-modal"
                                class="absolute top-4 right-4 text-gray-500 hover:text-red-500">
                            ✕
                        </button>

                        ${html}
                    </div>
                `;

            } catch (err) {

                console.error(err);

                alert('Không tải được form');
            }
        });

        document.addEventListener('click', e => {

            if (e.target.id === 'close-modal') {

                document.getElementById('address-modal')?.remove();
            }
        });
    </script>
    <script>
        document.addEventListener('click', async function (e) {

            const submitBtn = e.target.closest('#address-modal button[type="submit"]');

            if (!submitBtn) return;

            e.preventDefault();

            const form = submitBtn.closest('form');

            if (!form) return;

            try {

                const formData = new FormData(form);

                // submit ngầm
                await fetch(form.action, {
                    method: form.method || 'POST',
                    body: formData
                });

                // submit xong -> F5 checkout
                window.location.href = window.location.href;

            } catch (err) {

                console.error(err);

                alert('Lỗi khi tạo địa chỉ');
            }

        }, true);
    </script>
