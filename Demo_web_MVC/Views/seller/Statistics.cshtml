@model Demo_web_MVC.Models.ViewModel.Dashboard.StatisticsViewModel
<div class="space-y-xl">

            <!-- Overview Cards -->
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-gutter">
                <!-- Card 1 -->
                <div class="bg-surface-container-lowest p-lg rounded-xl shadow-[0px_4px_12px_rgba(0,0,0,0.05)] border border-outline-variant/10 hover:-translate-y-1 transition-all duration-300">
                    <div class="flex justify-between items-start mb-md">
                        <div class="w-12 h-12 rounded-xl bg-primary-container/10 flex items-center justify-center text-primary-container">
                            <span class="material-symbols-outlined">payments</span>
                        </div>

                    </div>
                    <p class="text-body-sm font-body-sm text-outline mb-xs">Tổng doanh thu</p>
                    <h3 class="font-price-lg text-price-lg text-on-surface">
                        @(Convert.ToDecimal(ViewBag.TotalRevenueAllTime) >= 1000000
                                                ? $"{Convert.ToDecimal(ViewBag.TotalRevenueAllTime) / 1000000:0.#}M"
                                                : $"{Convert.ToDecimal(ViewBag.TotalRevenueAllTime):0}")
                    </h3>
                </div>
                <!-- Card 2 -->
                <div class="bg-surface-container-lowest p-lg rounded-xl shadow-[0px_4px_12px_rgba(0,0,0,0.05)] border border-outline-variant/10 hover:-translate-y-1 transition-all duration-300">
                    <div class="flex justify-between items-start mb-md">
                        <div class="w-12 h-12 rounded-xl bg-tertiary-container/10 flex items-center justify-center text-tertiary-container">
                            <span class="material-symbols-outlined">shopping_bag</span>
                        </div>

                    </div>
                    <p class="text-body-sm font-body-sm text-outline mb-xs">Tổng đơn hàng</p>
                    <h3 class="font-price-lg text-price-lg text-on-surface">@ViewBag.TotalOrdersAllTime</h3>
                </div>
                <!-- Card 3 -->

                <div class="bg-surface-container-lowest p-lg rounded-xl shadow-[0px_4px_12px_rgba(0,0,0,0.05)] border border-outline-variant/10 hover:-translate-y-1 transition-all duration-300">
                    <div class="flex justify-between items-start mb-md">
                        <div class="w-12 h-12 rounded-xl bg-error-container/20 flex items-center justify-center text-error">
                            <span class="material-symbols-outlined">inventory</span>
                        </div>

                    </div>
                    <p class="text-body-sm font-body-sm text-outline mb-xs">Tổng sản phẩm</p>
                    <h3 class="font-price-lg text-price-lg text-on-surface">@ViewBag.TotalProductsAllTime</h3>
                </div>
            </div>
            <!-- Main Analytics Grid -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-lg">
                <!-- Cột trái: Biểu đồ doanh thu -->
                <div class="grid grid-cols-1 gap-lg">
                    <div class="bg-surface-container-lowest p-lg rounded-xl shadow border flex flex-col h-80">
                        <h4 class="font-headline-md mb-sm">Doanh thu từng đơn trong ngày</h4>
                        <canvas id="chartByOrder" class="w-full h-full"></canvas>
                    </div>

                    <div class="bg-surface-container-lowest p-lg rounded-xl shadow border flex flex-col h-80">
                        <h4 class="font-headline-md mb-sm">Doanh thu 7 ngày gần nhất</h4>
                        <canvas id="chart7Days" class="w-full h-full"></canvas>
                    </div>

                    <div class="bg-surface-container-lowest p-lg rounded-xl shadow border flex flex-col h-80">
                        <h4 class="font-headline-md mb-sm">Doanh thu 30 ngày gần nhất</h4>
                        <canvas id="chart30Days" class="w-full h-full"></canvas>
                    </div>
                </div>

                <!-- Cột phải: Biểu đồ trạng thái đơn hàng -->
                <div class="grid grid-cols-1 gap-lg">
                    <div class="bg-surface-container-lowest p-lg rounded-xl shadow border flex h-80 gap-lg relative">
                        <div class="flex-1 flex flex-col items-center justify-center relative">
                            <h4 class="font-headline-md mb-sm absolute top-2 text-center w-full">Trạng thái đơn trong ngày</h4>
                            <canvas id="orderStatusChartAll" class="w-3/5 h-3/5"></canvas>
                        </div>
                        <div id="orderStatusLegendAll" class="flex-1 flex flex-col justify-center gap-md"></div>
                    </div>

                    <div class="bg-surface-container-lowest p-lg rounded-xl shadow border flex h-80 gap-lg relative">
                        <div class="flex-1 flex flex-col items-center justify-center relative">
                            <h4 class="font-headline-md mb-sm absolute top-2 text-center w-full">Trạng thái đơn trong 7 ngày</h4>
                            <canvas id="orderStatusChart7Days" class="w-3/5 h-3/5"></canvas>
                        </div>
                        <div id="orderStatusLegend7Days" class="flex-1 flex flex-col justify-center gap-md"></div>
                    </div>

                    <div class="bg-surface-container-lowest p-lg rounded-xl shadow border flex h-80 gap-lg relative">
                        <div class="flex-1 flex flex-col items-center justify-center relative">
                            <h4 class="font-headline-md mb-sm absolute top-2 text-center w-full">trạng thái đơn trong 30 ngày</h4>
                            <canvas id="orderStatusChart30Days" class="w-3/5 h-3/5"></canvas>
                        </div>
                        <div id="orderStatusLegend30Days" class="flex-1 flex flex-col justify-center gap-md"></div>
                    </div>
                </div>
            </div>

        </div>

    <!-- Scripts for Charts -->
    @section Scripts {
        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
        <script>
            // --- Chart dữ liệu mẫu từ Model ---
            var labelsOrders = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.Orders.Select(o => ((DateTime)o.CreateAt).ToString("yyyy-MM-dd HH:mm"))));
            var dataOrders = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.Orders.Select(o => o.TotalAmount)));
            var labels7Days = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.RevenueLast7Days.Keys.Select(d => d.ToString("yyyy-MM-dd"))));
            var data7Days = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.RevenueLast7Days.Values));
            var labels30Days = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.RevenueLast30Days.Keys.Select(d => d.ToString("yyyy-MM-dd"))));
            var data30Days = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.RevenueLast30Days.Values));

            // --- Chart doanh thu ---
            new Chart(document.getElementById('chartByOrder'), {
                type: 'bar',
                data: { labels: labelsOrders, datasets: [{ label: 'Doanh thu từng đơn hôm nay', data: dataOrders, backgroundColor: 'rgba(34,197,94,0.7)' }] },
                options: { responsive: true, maintainAspectRatio: false, scales: { y: { beginAtZero: true } } }
            });
            new Chart(document.getElementById('chart7Days'), {
                type: 'bar',
                data: { labels: labels7Days, datasets: [{ label: 'Doanh thu 7 ngày', data: data7Days, backgroundColor: 'rgba(59,130,246,0.5)' }] },
                options: { responsive: true, maintainAspectRatio: false, scales: { y: { beginAtZero: true } } }
            });
            new Chart(document.getElementById('chart30Days'), {
                type: 'line',
                data: { labels: labels30Days, datasets: [{ label: 'Doanh thu 30 ngày', data: data30Days, borderColor: 'rgba(249,115,22,1)', backgroundColor: 'rgba(249,115,22,0.2)', fill:true, tension:0.3 }] },
                options: { responsive: true, maintainAspectRatio: false }
            });

            // --- Chart trạng thái đơn hàng ---
            var statusAll = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.OrderStatusAll));
            var status7Days = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.OrderStatusLast7Days));
            var status30Days = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.OrderStatusLast30Days));

            var statusLabels = ['Pending','Confirmed','Shipping','Completed','Cancelled'];
            var backgroundColors = ['rgba(107,114,128,0.7)','rgba(59,130,246,0.7)','rgba(34,197,94,0.7)','rgba(249,115,22,0.7)','rgba(239,68,68,0.7)'];
            var shrinkFactor = 0.8; // thu nhỏ 20%

                        function renderOrderStatusChart(canvasId, dataDict, legendContainerId){
                var data = statusLabels.map(l => dataDict[l] || 0);

                // Vẽ Doughnut
                new Chart(document.getElementById(canvasId), {
                    type:'doughnut',
                    data:{ labels: statusLabels, datasets:[{ data: data, backgroundColor: backgroundColors, borderWidth:1, radius:'80%', cutout:'50%' }]},
                    options:{ responsive:true, maintainAspectRatio:false, plugins:{legend:{display:false}} }
                });

                // Render Legend chi tiết bên phải
                var legendContainer = document.getElementById(legendContainerId);
                legendContainer.innerHTML='';
                var total = data.reduce((a,b)=>a+b,0);

                statusLabels.forEach(function(l,idx){
                    var count = data[idx];
                    var percent = total ? Math.round((count/total)*100) : 0;
                    var item = document.createElement('div');
                    item.className='flex items-center justify-between';
                    item.innerHTML = `
                        <div class="flex items-center gap-sm">
                            <span class="w-3 h-3 rounded-full" style="background-color:${backgroundColors[idx]}"></span>
                            <span class="text-body-sm font-body-sm text-outline">${l}</span>
                        </div>
                        <span class="text-label-bold font-label-bold">${percent}%</span>
                    `;
                    legendContainer.appendChild(item);
                });
            }

            renderOrderStatusChart('orderStatusChartAll',statusAll,'orderStatusLegendAll');
            renderOrderStatusChart('orderStatusChart7Days',status7Days,'orderStatusLegend7Days');
            renderOrderStatusChart('orderStatusChart30Days',status30Days,'orderStatusLegend30Days');
        </script>
    }