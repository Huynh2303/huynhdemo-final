@model Demo_web_MVC.Models.ViewModel.Dashboard.DashboardViewModel
<!-- Statistical Cards Grid -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-gutter mb-xl">
    <!-- Card 1 -->
    <div class="bg-surface p-lg rounded-xl shadow-[0px_4px_12px_rgba(0,0,0,0.05)] border-l-4 border-primary-container flex items-center justify-between hover:-translate-y-1 transition-transform duration-200">
        <div>
            <p class="font-label-bold text-label-bold text-on-surface-variant uppercase tracking-wider mb-xs">Tổng Đơn Hàng</p>
            <p class="font-display-lg text-display-lg text-on-surface">@ViewBag.TotalOrders</p>
        </div>
        <div class="w-12 h-12 rounded-full bg-primary-container/10 flex items-center justify-center">
            <span class="material-symbols-outlined text-primary-container" data-icon="shopping_bag" style="font-variation-settings: 'FILL' 1;">shopping_bag</span>
        </div>
    </div>
    <!-- Card 2 -->
    <div class="bg-surface p-lg rounded-xl shadow-[0px_4px_12px_rgba(0,0,0,0.05)] border-l-4 border-tertiary-container flex items-center justify-between hover:-translate-y-1 transition-transform duration-200">
        <div>
            <p class="font-label-bold text-label-bold text-on-surface-variant uppercase tracking-wider mb-xs">Đơn Hôm Nay</p>
            <p class="font-display-lg text-display-lg text-on-surface">@ViewBag.TotalOrdersToday</p>
        </div>
        <div class="w-12 h-12 rounded-full bg-tertiary-container/10 flex items-center justify-center">
            <span class="material-symbols-outlined text-tertiary-container" data-icon="today" style="font-variation-settings: 'FILL' 1;">today</span>
        </div>
    </div>
    <!-- Card 3 -->
    <div class="bg-surface p-lg rounded-xl shadow-[0px_4px_12px_rgba(0,0,0,0.05)] border-l-4 border-primary flex items-center justify-between hover:-translate-y-1 transition-transform duration-200">
        <div>
            <p class="font-label-bold text-label-bold text-on-surface-variant uppercase tracking-wider mb-xs">Tổng Doanh Thu</p>
            @* <p class="font-display-lg text-display-lg text-on-surface">@ViewBag.TotalRevenue</p> *@
            <p class="font-display-lg text-display-lg text-on-surface">
                @(ViewBag.TotalRevenue >= 1000000
                                ? $"{ViewBag.TotalRevenue / 1000000m:0.#}M"
                                : $"{ViewBag.TotalRevenue:N0}")
            </p>
        </div>
        <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center">
            <span class="material-symbols-outlined text-primary" data-icon="payments" style="font-variation-settings: 'FILL' ;">payments</span>
        </div>
    </div>
    <!-- Card 4 -->
    <div class="bg-surface p-lg rounded-xl shadow-[0px_4px_12px_rgba(0,0,0,0.05)] border-l-4 border-outline flex items-center justify-between hover:-translate-y-1 transition-transform duration-200">
        <div>
            <p class="font-label-bold text-label-bold text-on-surface-variant uppercase tracking-wider mb-xs">Sản Phẩm</p>
            <p class="font-display-lg text-display-lg text-on-surface">@ViewBag.Product</p>
        </div>
        <div class="w-12 h-12 rounded-full bg-outline/10 flex items-center justify-center">
            <span class="material-symbols-outlined text-outline" data-icon="inventory_2" style="font-variation-settings: 'FILL' 1;">inventory_2</span>
        </div>
    </div>
</div>
<div class="grid grid-cols-1 lg:grid-cols-3 gap-xl">
    <!-- Recent Orders Table (Bento Grid Area 2/3) -->
    <div class="lg:col-span-2 bg-surface rounded-xl shadow-[0px_8px_24px_rgba(0,0,0,0.1)] overflow-hidden">
        <div class="p-lg border-b border-outline-variant flex justify-between items-center">
            <h3 class="font-headline-md text-headline-md text-primary">Đơn hàng gần đây</h3>
            <button class="text-primary font-label-bold text-label-bold hover:underline">Tất cả đơn hàng</button>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead class="bg-surface-container-low text-on-surface-variant font-label-bold text-label-bold">
                    <tr>
                        <th class="p-md">Mã đơn</th>
                        <th class="p-md">Khách hàng</th>
                        <th class="p-md">Trạng thái</th>
                        <th class="p-md text-center">AI</th>
                        <th class="p-md text-right">Tổng tiền</th>
                        <th class="p-md text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="text-body-sm">

                    @if (Model.Orders == null || Model.Orders.Items == null || !Model.Orders.Items.Any())
                    {
                        <tr>
                            <td colspan="6" class="p-md text-center text-on-surface-variant">
                                Chưa có đơn hàng nào.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var order in Model.Orders.Items)
                        {
                            var riskLevel = order.FraudAnalysis?.RiskLevel;

                            var riskText = riskLevel switch
                            {
                                "High" => "Rủi ro cao",
                                "Medium" => "Cần kiểm tra",
                                "Low" => "An toàn",
                                "DataWarning" => "Thiếu dữ liệu",
                                _ => "Chưa phân tích"
                            };

                            var riskClass = riskLevel switch
                            {
                                "High" => "bg-red-100 text-red-800 border border-red-200",
                                "Medium" => "bg-yellow-100 text-yellow-800 border border-yellow-200",
                                "Low" => "bg-green-100 text-green-800 border border-green-200",
                                "DataWarning" => "bg-orange-100 text-orange-800 border border-orange-200",
                                _ => "bg-gray-100 text-gray-600 border border-gray-200"
                            };

                            <tr class="border-b border-outline-variant hover:bg-surface-container-lowest transition-colors">
                                <td class="p-md font-bold">@order.Id</td>

                                <td class="p-md">@order.user</td>

                                <td class="p-md">
                                    <span class="px-sm py-xs bg-yellow-100 text-yellow-800 rounded-full font-label-bold text-[10px] uppercase">
                                        @order.Status
                                    </span>
                                </td>

                                <td class="p-md text-center">
                                    <span class="inline-flex items-center px-3 py-1 rounded-full text-[11px] font-semibold @riskClass">
                                        @riskText
                                    </span>
                                </td>

                                <td class="p-md text-right font-price-lg text-price-lg">
                                    @(order.TotalAmount >= 1000000
                                        ? $"{order.TotalAmount / 1000000m:0.#}M"
                                        : $"{order.TotalAmount:N0}")
                                </td>

                                <td class="p-md text-center">
                                    <a asp-action="DetailsOrder"
                                       asp-controller="Seller"
                                       asp-route-orderId="@order.Id"
                                       class="text-primary-container hover:bg-primary-container/10 px-sm py-xs rounded-lg transition-colors">
                                        Xem chi tiết
                                    </a>
                                </td>
                            </tr>
                        }
                    }

                </tbody>
            </table>
            @if (Model.Orders != null && Model.Orders.TotalPages > 1)
            {
                <div class="px-6 py-4 bg-surface-container-low border-t border-outline-variant flex items-center justify-between">

                    <div class="text-sm text-on-surface-variant">
                        Trang @Model.Orders.PageIndex / @Model.Orders.TotalPages
                    </div>

                    <div class="flex items-center gap-2">

                        @if (Model.Orders.HasPreviousPage)
                        {
                            <a asp-action="Dashboard"
                               asp-route-orderPage="@(Model.Orders.PageIndex - 1)"
                               asp-route-productPage="@Model.Products.PageIndex"
                               class="p-2 rounded-lg border border-outline-variant hover:bg-surface transition-colors">
                                <span class="material-symbols-outlined text-[20px]">chevron_left</span>
                            </a>
                        }
                        else
                        {
                            <button type="button"
                                    disabled
                                    class="p-2 rounded-lg border border-outline-variant opacity-50 transition-colors">
                                <span class="material-symbols-outlined text-[20px]">chevron_left</span>
                            </button>
                        }

                        @for (int i = 1; i <= Model.Orders.TotalPages; i++)
                        {
                            var activeClass = i == Model.Orders.PageIndex
                                ? "bg-primary text-on-primary"
                                : "hover:bg-surface-container-high";

                            <a asp-action="Dashboard"
                               asp-route-orderPage="@i"
                               asp-route-productPage="@Model.Products.PageIndex"
                               class="w-8 h-8 rounded-lg font-label-md text-label-md flex items-center justify-center transition-colors @activeClass">
                                @i
                            </a>
                        }

                        @if (Model.Orders.HasNextPage)
                        {
                            <a asp-action="Dashboard"
                               asp-route-orderPage="@(Model.Orders.PageIndex + 1)"
                               asp-route-productPage="@Model.Products.PageIndex"
                               class="p-2 rounded-lg border border-outline-variant hover:bg-surface transition-colors">
                                <span class="material-symbols-outlined text-[20px]">chevron_right</span>
                            </a>
                        }
                        else
                        {
                            <button type="button"
                                    disabled
                                    class="p-2 rounded-lg border border-outline-variant opacity-50 transition-colors">
                                <span class="material-symbols-outlined text-[20px]">chevron_right</span>
                            </button>
                        }

                    </div>
                </div>
            }
        </div>
    </div>
    <!-- Quick Product Management (Bento Grid Area 1/3) -->
    <div class="bg-surface rounded-xl shadow-[0px_8px_24px_rgba(0,0,0,0.1)] overflow-hidden flex flex-col">
        <div class="p-lg border-b border-outline-variant">
            <h3 class="font-headline-md text-headline-md text-primary">Sản phẩm nổi bật</h3>
        </div>
        <div class="p-md flex-1 space-y-md overflow-y-auto max-h-[400px]">
            @foreach (var item in Model.Products.Items)
            {
                <!-- Simulated Razor Loop for Product Item -->
                <div class="flex items-center gap-md p-sm rounded-lg hover:bg-surface-container-low transition-all">
                    <div class="w-16 h-16 rounded-lg overflow-hidden flex-shrink-0">
                        <img alt="Smart Watch" class="w-full h-full object-cover" data-alt="A premium smart watch with a vibrant blue silicone strap and a sleek black digital face, presented on a clean white surface with soft ambient lighting. The product photography has a minimalist, high-end feel, using a vibrant blue and cool white color palette that fits a modern tech dashboard aesthetic. The lighting creates subtle reflections on the glass face, emphasizing the high-quality materials."
                             src="@Url.Content(item.imageUrl.FirstOrDefault() ?? "/uploads/images/no-image.jpg")" />
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="font-label-bold text-label-bold text-on-surface truncate">@item.Name</p>
                        <p class="text-primary font-price-lg text-price-lg truncate max-w-[170px]">
                            @{
                                var price = item?.Variants?.FirstOrDefault()?.Price ?? 0;
                            }

                        @(price >= 1000000
                                                ? $"{price / 1000000m:0.#}M".Replace(".", ",")
                                                : $"{price:N0}đ")
                    </p>
                        <p class="text-body-sm text-on-surface-variant">Kho: @item?.Variants?.FirstOrDefault()?.Stock</p>
                    </div>
                    <div class="flex flex-col gap-xs">
                        <form asp-action="Edit" asp-controller="Seller" asp-route-id="@item.Id" method="get">
                            <button class="material-symbols-outlined text-outline hover:text-primary transition-colors text-[20px]" data-icon="edit">edit</button>
                        </form>


                        <form asp-action="DeleteProduct" asp-controller="Seller" asp-route-id="@item.Id" method="post">
                            <button class="material-symbols-outlined text-outline hover:text-error transition-colors text-[20px]" data-icon="delete">delete</button>

                        </form>
                    </div>
                </div>
            }


            
        </div>
        <div class="p-md bg-surface-container-low text-center">
            <a asp-action="ProductsManager" asp-controller="Seller" class="text-primary font-label-bold text-label-bold hover:underline">Quản lý kho hàng</a>
        </div>
    </div>
</div>
