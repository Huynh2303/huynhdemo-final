@model List<Demo_web_MVC.Models.ViewModel.Dashboard.DetailsOrderDashboardViewmodel>

@{
    var order = Model?.FirstOrDefault();
    var address = order?.AddressView;
    var items = order?.OderItemViews ?? new List<Demo_web_MVC.Models.ViewModel.Oder.OderItemViewModel>();

    decimal subTotal = items.Sum(x => x.Price * x.Quantity);
    decimal shippingFee = 30000;
    decimal total = order?.TotalAmount ?? subTotal + shippingFee;

    string orderCode = order != null ? $"DH-{order.OrderId}" : "DH-UNKNOWN";
}

<div class="space-y-lg">
        

        <div class="p-lg max-w-7xl mx-auto space-y-lg">

            @if (order == null)
            {
                <div class="bg-error-container text-error p-lg rounded-xl">
                    Không tìm thấy thông tin đơn hàng.
                </div>
            }
            else
            {
                
                <div class="flex justify-between items-end">
                    <div>
                       

                        <h2 class="font-display-lg text-display-lg text-on-surface">
                            Đơn hàng @order.OrderId
                        </h2>
                    </div>

                    
                </div>

                <div class="grid grid-cols-12 gap-gutter">
                    <div class="col-span-8 grid grid-cols-2 gap-gutter">

                        <div class="bg-surface-container-lowest p-lg rounded-xl shadow-[0px_4px_12px_rgba(0,0,0,0.05)] border border-outline-variant/30">
                            <div class="flex items-center gap-md mb-md">
                                <div class="w-10 h-10 rounded-full bg-primary/10 text-primary flex items-center justify-center">
                                    <span class="material-symbols-outlined">person</span>
                                </div>

                                <h3 class="font-headline-md text-headline-md">
                                    Thông tin khách hàng
                                </h3>
                            </div>

                            <div class="space-y-sm">
                                <div class="flex justify-between gap-md">
                                    <span class="text-on-surface-variant font-body-sm">Họ và tên:</span>
                                    <span class="text-on-surface font-label-bold text-right">
                                        @(address?.RecipientName ?? order.AddressView!.RecipientName ?? "Chưa có")
                                    </span>
                                </div>

                                <div class="flex justify-between gap-md">
                                    <span class="text-on-surface-variant font-body-sm">Số điện thoại:</span>
                                    <span class="text-on-surface font-label-bold text-right">
                                        @(address?.PhoneNumber ?? order.AddressView!.PhoneNumber ?? "Chưa có")
                                    </span>
                                </div>

                                <div class="flex justify-between gap-md">
                                    <span class="text-on-surface-variant font-body-sm">Email:</span>
                                    <span class="text-on-surface font-label-bold text-right">
                                        @(order.Email ?? "Chưa có")
                                    </span>
                                </div>

                                <div class="pt-sm mt-sm border-t border-outline-variant/30">
                                    <p class="text-on-surface-variant font-body-sm mb-xs">
                                        Địa chỉ giao hàng:
                                    </p>

                                    <p class="text-on-surface font-body-base leading-snug">
                                        @if (address != null)
                                        {
                                            @($"{address.AddressLine}, {address.City}, {address.Country}")
                                        }
                                        else
                                        {
                                            <span>Chưa có địa chỉ giao hàng</span>
                                        }
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div class="bg-surface-container-lowest p-lg rounded-xl shadow-[0px_4px_12px_rgba(0,0,0,0.05)] border border-outline-variant/30">
                            <div class="flex items-center gap-md mb-md">
                                <div class="w-10 h-10 rounded-full bg-tertiary-container/20 text-primary flex items-center justify-center">
                                    <span class="material-symbols-outlined">payments</span>
                                </div>

                                <h3 class="font-headline-md text-headline-md">
                                    Thanh toán &amp; Vận chuyển
                                </h3>
                            </div>

                            <div class="space-y-sm">
                                <div class="flex justify-between gap-md">
                                    <span class="text-on-surface-variant font-body-sm">COD</span>
                                    @foreach(var oder in Model!)
                                    {
                                        <span class="text-on-surface font-label-bold text-right">@oder.OrderStatus</span>
                                    }
                                    
                                </div>

                                <div class="flex justify-between gap-md">
                                    <span class="text-on-surface-variant font-body-sm">Trạng thái TT:</span>
                                    <span class="px-sm py-1 bg-surface-container-high text-on-surface text-[10px] font-bold rounded-full uppercase">
                                        Chưa có
                                    </span>
                                </div>

                                <div class="flex justify-between gap-md">
                                    <span class="text-on-surface-variant font-body-sm">Đơn vị vận chuyển:</span>
                                    <span class="text-on-surface font-label-bold text-right">J&T</span>
                                </div>

                                <div class="flex justify-between gap-md">
                                    <span class="text-on-surface-variant font-body-sm">Mã vận đơn:</span>
                                    <span class="text-primary font-label-bold underline cursor-pointer">Mdfji123</span>
                                </div>

                                <div class="pt-sm mt-sm border-t border-outline-variant/30">
                                    <p class="text-on-surface-variant font-body-sm mb-xs">Ghi chú từ khách:</p>
                                    <p class="text-on-surface italic font-body-sm">Chưa có ghi chú.</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-span-4 bg-surface-container-lowest p-lg rounded-xl shadow-[0px_4px_12px_rgba(0,0,0,0.05)] border-2 border-primary-container/20">
                        <div class="flex items-center gap-md mb-lg">
                            <div class="w-10 h-10 rounded-full bg-primary-container text-white flex items-center justify-center">
                                <span class="material-symbols-outlined">edit_square</span>
                            </div>

                            <h3 class="font-headline-md text-headline-md">
                                Xử lý trạng thái
                            </h3>
                        </div>

                        <div class="space-y-lg">

                            <div>
                                <label class="font-label-bold text-label-bold text-on-surface-variant block">
                                    Trạng thái
                                </label>

                                <div class="w-full bg-surface-container-low border border-outline-variant rounded-lg p-md flex items-center justify-between">
                                    <div class="flex items-center gap-sm">
                                        <span class="material-symbols-outlined text-primary text-[20px]">
                                            info
                                        </span>

                                        <span class="text-body-sm text-on-surface-variant">
                                            Trạng thái hiện tại
                                        </span>
                                    </div>

                                    <span class="px-md py-xs rounded-full bg-primary-container/10 text-primary font-label-bold text-label-bold uppercase">
                                        @Model.FirstOrDefault()?.OrderStatus
                                    </span>
                                </div>
                            </div>

                            <div class="space-y-sm">

                                <!-- Nút cập nhật trạng thái / nhận đơn / chuyển sang Shipping -->
                                <form asp-action="UpdateOrderStatus"
                                      asp-controller="Seller"
                                      asp-route-orderId="orderId"
                                      method="post">

                                    @Html.AntiForgeryToken()

                                    <input type="hidden" name="orderId" value="@order.OrderId" />

                                    <button class="w-full py-md bg-primary-container text-white font-label-bold rounded-lg hover:shadow-lg transition-all flex items-center justify-center gap-md"
                                            type="submit">
                                        <span class="material-symbols-outlined">check_circle</span>
                                        Cập nhật trạng thái
                                    </button>
                                </form>


                                <!-- Nút hủy đơn hàng -->
                                @if (order.OrderStatus != "Completed" && order.OrderStatus != "Cancelled")
                                {
                                    <form asp-action="CancelOrder"
                                          asp-controller="Seller"
                                          asp-route-orderId="orderId"
                                          method="post"
                                          onsubmit="return confirm('Bạn có chắc chắn muốn hủy đơn hàng này không?');">

                                        @Html.AntiForgeryToken()

                                        <input type="hidden" name="orderId" value="@order.OrderId" />

                                        <button class="w-full py-md border border-error text-error font-label-bold rounded-lg hover:bg-error/5 transition-all flex items-center justify-center gap-md"
                                                type="submit">
                                            <span class="material-symbols-outlined">cancel</span>
                                            Hủy đơn hàng
                                        </button>
                                    </form>
                                }

                            </div>
                            <!-- kết quả AI-->
                            <div class="bg-surface-container-low rounded-lg p-md">
                                <p class="text-label-bold text-outline-variant uppercase mb-xs">
                                    Đánh giá rủi ro AI
                                </p>

                                @if (order.FraudAnalysis != null)
                                {
                                    var riskLevel = order.FraudAnalysis.RiskLevel;

                                    var riskText = riskLevel switch
                                    {
                                        "High" => "Rủi ro cao",
                                        "Medium" => "Cần kiểm tra",
                                        "Low" => "An toàn",
                                        "DataWarning" => "Thiếu dữ liệu",
                                        _ => "Không xác định"
                                    };

                                    var riskBadgeClass = riskLevel switch
                                    {
                                        "High" => "bg-red-100 text-red-800 border border-red-200",
                                        "Medium" => "bg-yellow-100 text-yellow-800 border border-yellow-200",
                                        "Low" => "bg-green-100 text-green-800 border border-green-200",
                                        "DataWarning" => "bg-orange-100 text-orange-800 border border-orange-200",
                                        _ => "bg-gray-100 text-gray-600 border border-gray-200"
                                    };

                                    var dotClass = riskLevel switch
                                    {
                                        "High" => "bg-red-500",
                                        "Medium" => "bg-yellow-500",
                                        "Low" => "bg-green-500",
                                        "DataWarning" => "bg-orange-500",
                                        _ => "bg-gray-400"
                                    };

                                    <div class="space-y-sm">

                                        <div class="flex items-start gap-sm">
                                            <div class="w-2 h-2 mt-2 rounded-full @dotClass"></div>

                                            <div class="flex-1">
                                                <div class="flex items-center justify-between gap-sm">
                                                    <p class="text-body-sm font-bold">
                                                        Mức cảnh báo
                                                    </p>

                                                    <span class="inline-flex items-center px-sm py-xs rounded-full text-[10px] font-bold uppercase @riskBadgeClass">
                                                        @riskText
                                                    </span>
                                                </div>

                                               
                                            </div>
                                        </div>

                                        <div class="flex items-start gap-sm">
                                            <div class="w-2 h-2 mt-2 rounded-full bg-primary-container"></div>

                                            <div>
                                                <p class="text-body-sm font-bold">
                                                    Lý do cảnh báo
                                                </p>

                                                @if (order.FraudAnalysis.Reasons != null && order.FraudAnalysis.Reasons.Any())
                                                {
                                                    <ul class="mt-xs space-y-xs">
                                                        @foreach (var reason in order.FraudAnalysis.Reasons)
                                                        {
                                                            <li class="text-[12px] text-outline leading-relaxed">
                                                                - @reason
                                                            </li>
                                                        }
                                                    </ul>
                                                }
                                                else
                                                {
                                                    <p class="text-[12px] text-outline mt-xs leading-relaxed">
                                                        Chưa có lý do cảnh báo chi tiết.
                                                    </p>
                                                }
                                            </div>
                                        </div>

                                        <div class="flex items-start gap-sm">
                                            <div class="w-2 h-2 mt-2 rounded-full bg-outline"></div>

                                            <div>
                                                <p class="text-body-sm font-bold">
                                                    Thời gian phân tích
                                                </p>

                                                <p class="text-[10px] text-outline">
                                                    @order.FraudAnalysis.CreatedAt.ToString("dd/MM/yyyy - HH:mm")
                                                </p>
                                            </div>
                                        </div>

                                    </div>
                                }
                                else
                                {
                                    <div class="flex items-start gap-sm">
                                        <div class="w-2 h-2 mt-2 rounded-full bg-gray-400"></div>

                                        <div>
                                            <p class="text-body-sm font-bold">
                                                Chưa có kết quả AI
                                            </p>

                                            <p class="text-[10px] text-outline">
                                                Đơn hàng này chưa được hệ thống phân tích rủi ro.
                                            </p>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                </div>

                <div class="bg-surface-container-lowest rounded-xl shadow-[0px_4px_12px_rgba(0,0,0,0.05)] border border-outline-variant/30 overflow-hidden">
                    <div class="px-lg py-md border-b border-outline-variant/30 flex justify-between items-center">
                        <h3 class="font-headline-md text-headline-md">
                            Danh sách sản phẩm
                        </h3>

                        <span class="bg-surface-container-high px-md py-xs rounded-full text-label-bold text-on-surface">
                            @items.Count sản phẩm
                        </span>
                    </div>

                    <div class="overflow-x-auto">
                        <table class="w-full border-collapse">
                            <thead>
                                <tr class="bg-surface-container-low text-left">
                                    <th class="px-lg py-md font-label-bold text-label-bold text-on-surface-variant">Ảnh</th>
                                    <th class="px-lg py-md font-label-bold text-label-bold text-on-surface-variant">Sản phẩm</th>
                                    <th class="px-lg py-md font-label-bold text-label-bold text-on-surface-variant">Giá</th>
                                    <th class="px-lg py-md font-label-bold text-label-bold text-on-surface-variant">Số lượng</th>
                                    <th class="px-lg py-md font-label-bold text-label-bold text-on-surface-variant text-right">Thành tiền</th>
                                </tr>
                            </thead>

                            <tbody class="divide-y divide-outline-variant/20">
                                @if (items.Any())
                                {
                                    foreach (var item in items)
                                    {
                                        <tr class="hover:bg-surface-container-low transition-colors group">
                                            <td class="px-lg py-md w-24">
                                                <div class="w-16 h-16 rounded-lg overflow-hidden border border-outline-variant/30">
                                                    <img alt="@item.Name"
                                                         class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300"
                                                         src="@(string.IsNullOrEmpty(item.Img) ? "/uploads/images/no-image.jpg" : item.Img)" />
                                                </div>
                                            </td>

                                            <td class="px-lg py-md">
                                                <p class="font-label-bold text-body-base text-on-surface">
                                                    @item.Name
                                                </p>
                                            </td>

                                            <td class="px-lg py-md font-price-lg text-body-base text-on-surface">
                                                @item.Price.ToString("N0")đ
                                            </td>

                                            <td class="px-lg py-md font-body-base text-on-surface">
                                                @item.Quantity
                                            </td>

                                            <td class="px-lg py-md text-right font-price-lg text-price-lg text-primary">
                                                @((item.Price * item.Quantity).ToString("N0"))đ
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="px-lg py-lg text-center text-on-surface-variant">
                                            Đơn hàng chưa có sản phẩm.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="bg-surface-container-low px-lg py-lg flex justify-end">
                        <div class="w-80 space-y-sm">
                            <div class="flex justify-between text-body-sm text-on-surface-variant">
                                <span>Tạm tính:</span>
                                <span>@subTotal.ToString("N0")đ</span>
                            </div>

                            <div class="flex justify-between text-body-sm text-on-surface-variant">
                                <span>Phí vận chuyển:</span>
                                <span>Miễn phí</span>
                            </div>

                            <div class="pt-sm mt-sm border-t border-outline-variant flex justify-between items-center">
                                <span class="font-headline-md text-headline-md text-on-surface">Tổng cộng:</span>
                                <span class="font-price-lg text-[28px] text-primary">
                                    @total.ToString("N0")đ
                                </span>
                            </div>
                        </div>
                    </div>
                </div>

                
            }

        </div>
 </div>

    <div class="hidden fixed bottom-10 right-10 bg-inverse-surface text-white px-lg py-md rounded-xl shadow-2xl flex items-center gap-md z-[100]" id="toast-success">
        <span class="material-symbols-outlined text-green-400" style="font-variation-settings: 'FILL' ;">check_circle</span>
        <p class="font-label-bold">Cập nhật trạng thái thành công!</p>
    </div>
